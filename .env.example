ALLEGRO_CLIENT_ID=your_client_id_here
ALLEGRO_CLIENT_SECRET=your_client_secret_here
ALLEGRO_ENV=sandbox          # prod | sandbox

MAX_OFFERS=120               # cap offers processed per search
IMAGE_CONCURRENCY=8          # parallel image download/CV workers
DELTA_E_THRESHOLD=10         # default ΔE match threshold
CACHE_DIR=.cache

STORAGE_SECRET=change-me-to-a-random-string   # required for persistent dark-mode preference
