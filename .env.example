ALLEGRO_CLIENT_ID=your_client_id_here
ALLEGRO_CLIENT_SECRET=your_client_secret_here
ALLEGRO_ENV=sandbox          # prod | sandbox

# Strongly recommended: pin the filament category ID so the app never has to
# discover it via BFS. Run `uv run allegro-smoke-test --discover-category` once
# to find the correct ID for your environment, then set it here.
# On production Allegro the "Filamenty do drukarek 3D" category ID is typically
# a numeric string like "2294" — verify with the smoke test.
ALLEGRO_FILAMENT_CATEGORY_ID=

MAX_OFFERS=120               # cap offers processed per search
IMAGE_CONCURRENCY=8          # parallel image download/CV workers
DELTA_E_THRESHOLD=10         # default ΔE match threshold
CACHE_DIR=.cache
